{
  "name": "@isuperhero/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file ../../.env --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@colyseus/core": "0.17.39",
    "@colyseus/schema": "^4.0.17",
    "@colyseus/ws-transport": "^0.17.9",
    "@isuperhero/game-data": "workspace:*",
    "@isuperhero/game-logic": "workspace:*",
    "@isuperhero/types": "workspace:*",
    "colyseus": "^0.17.8",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@colyseus/testing": "^0.17.11",
    "@types/express": "^5.0.6",
    "drizzle-kit": "^0.31.9",
    "vitest": "^4.0.18"
  }
}
