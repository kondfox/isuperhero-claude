# Copy to .env and fill in real values (never commit .env)

# Hetzner
HCLOUD_TOKEN_STAGE=
HCLOUD_TOKEN_PROD=

# PostgreSQL (port 5433 to avoid conflict with local PostgreSQL)
DATABASE_URL=postgresql://isuperhero:password@localhost:5433/isuperhero_dev

# GitHub (for MCP server)
GITHUB_TOKEN=

# App
PORT=2567
NODE_ENV=development

# Auth
JWT_SECRET=change-me-to-a-random-32-char-string
APP_URL=http://localhost:5173

# Email (optional — logs to console if SMTP_HOST is empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@isuperhero.online
