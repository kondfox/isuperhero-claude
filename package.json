{
  "name": "isuperhero",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter='*' dev",
    "build": "bun run --filter='*' build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky",
    "db:generate": "bun run --env-file .env --filter @isuperhero/server db:generate",
    "db:migrate": "bun run --env-file .env --filter @isuperhero/server db:migrate",
    "db:seed": "bun run --env-file .env --filter @isuperhero/server db:seed",
    "db:studio": "bun run --env-file .env --filter @isuperhero/server db:studio",
    "storybook": "bun run --filter @isuperhero/web storybook"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "typescript": "^5.7.3",
    "vitest": "^3.1.4"
  },
  "trustedDependencies": ["@biomejs/biome"]
}
